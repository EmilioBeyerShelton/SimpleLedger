{
  "name": "simpleledger",
  "private": true,
  "version": "1.0.0",
  "description": "SimpleLedger — expense tracker. React + Capacitor (iOS) + Electron (macOS) + Web.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k -s first \"vite\" \"wait-on http://localhost:5173 && ELECTRON_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:preview": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder",
    "cap:sync": "npm run build && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3 || echo 'electron-rebuild failed — run the rebuild:electron script manually (needs Xcode Command Line Tools) before using the Electron build. Web dev is unaffected.'",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^6.0.2",
    "@capacitor/app": "^6.0.0",
    "@capacitor/camera": "^6.0.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/filesystem": "^6.0.1",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/share": "^6.0.2",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.436.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^31.4.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.41",
    "wait-on": "^7.2.0",
    "tailwindcss": "^3.4.10",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  },
  "build": {
    "appId": "com.simpleledger.app",
    "productName": "SimpleLedger",
    "files": ["dist/**/*", "electron/**/*"],
    "mac": {
      "category": "public.app-category.finance",
      "target": ["dmg"]
    }
  }
}
